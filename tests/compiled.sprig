// Compiler smoke test — no lists, shapes, or input

define add(a, b):
    give back a + b

define factorial(n):
    when n < 2:
        give back 1
    give back n * factorial(n - 1)

define is_even(n):
    give back (n / 2) * 2 is n

// Arithmetic and functions
let x = add(3, 4)
print(x)                          // 7

// Recursion
print(factorial(5))               // 120

// String concatenation
let name = "sprig"
print("Hello " + name + "!")      // Hello sprig!

// Boolean and branching
when is_even(4):
    print("four is even")
otherwise:
    print("four is odd")

// Chained conditions
let score = 85
when score > 90:
    print("A")
otherwise when score > 80:
    print("B")
otherwise:
    print("C")

// While loop with mutable variable
let mutable counter = 0
as long as counter < 5:
    let counter = counter + 1
print("counted to " + to_text(counter))

// stop and skip
let mutable n = 0
as long as n < 10:
    let n = n + 1
    when n is 3:
        skip
    when n is 7:
        stop
    print(n)
